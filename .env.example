# --- Supabase ---
# Project URL (e.g. https://xxxxx.supabase.co). Public.
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key. SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Database ---
# Direct Postgres connection used by Drizzle migrations and server-side queries.
# Use the Supabase pooled connection string for runtime, direct for migrations.
DATABASE_URL=
DATABASE_DIRECT_URL=

# --- App ---
# Public site URL used for redirects, signed-link generation, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Logging level: trace | debug | info | warn | error. Default info.
LOG_LEVEL=info

# --- AI (placeholder, owned by search-ai-agent) ---
# ANTHROPIC_API_KEY=
